# Dead Letters - Environment Configuration
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be committed.

# =============================================================================
# PRODUCTION MODE (Recommended for App Store / Play Store)
# =============================================================================
# Your Vercel proxy URL, including the /api/gemini path.
# Deploy the proxy first (see proxy/README.md), then put the real URL here.
# IMPORTANT: replace the example below with YOUR deployment — the app cannot
# reach a placeholder host (e.g. "...vercel.app/api/gemini" must be real).
GEMINI_PROXY_URL=https://your-project.vercel.app/api/gemini

# Optional: Add extra authentication between your app and proxy
# Generate a random string and add it to both here AND your Vercel env vars
# APP_TOKEN=your_random_secret_token_here

# =============================================================================
# DEVELOPMENT MODE (Local testing only - NOT secure for distribution)
# =============================================================================
# Direct Gemini API key - ONLY use this for local development
# Get your key from: https://aistudio.google.com/
# WARNING: This key will be embedded in the app binary if used
# GEMINI_API_KEY=your_gemini_api_key_here
